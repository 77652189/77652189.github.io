---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { title, titleZh, description, descriptionZh, tags, github, stars, date, language } = project.data;

const dateStr = date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title={`${title} — 77652189`} description={descriptionZh}>
  <article>

    <a href="/projects" class="inline-flex items-center gap-1 text-xs font-mono text-slate-600 hover:text-indigo-400 transition-colors mb-10">
      ← 所有项目
    </a>

    <header class="mb-10">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h1 class="text-3xl font-bold font-mono text-white">{title}</h1>
          <p class="text-slate-500 mt-1 text-sm">{titleZh}</p>
        </div>
        {stars > 0 && (
          <span class="text-amber-400 font-mono text-sm shrink-0 mt-1">★ {stars}</span>
        )}
      </div>

      <div class="mt-5 space-y-1">
        <p class="text-slate-300 leading-relaxed">{descriptionZh}</p>
        <p class="text-sm text-slate-500">{description}</p>
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mt-5">
        {tags.map(tag => (
          <span class="text-xs font-mono bg-slate-800 text-slate-500 border border-slate-700 px-2.5 py-1 rounded">
            {tag}
          </span>
        ))}
        {language && (
          <span class="text-xs font-mono bg-indigo-950 text-indigo-400 border border-indigo-900 px-2.5 py-1 rounded">
            {language}
          </span>
        )}
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-4 mt-6">
        <a
          href={github}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-sm bg-white text-slate-950 px-4 py-2 rounded-lg font-medium hover:bg-slate-100 transition-colors"
        >在 GitHub 查看 ↗</a>
        <span class="text-xs font-mono text-slate-700">{dateStr}</span>
      </div>
    </header>

    <div class="border-t border-slate-800 mb-8"></div>

    <!-- Markdown content -->
    <div class="prose prose-invert max-w-none
      prose-headings:font-semibold prose-headings:text-slate-100
      prose-h2:text-base prose-h2:font-mono prose-h2:mt-8 prose-h2:mb-3 prose-h2:text-slate-300
      prose-p:text-slate-400 prose-p:leading-relaxed
      prose-li:text-slate-400
      prose-strong:text-slate-200
      prose-code:text-indigo-400 prose-code:bg-indigo-950/50 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-mono prose-code:border prose-code:border-indigo-900/50 prose-code:before:content-none prose-code:after:content-none
    ">
      <Content />
    </div>

  </article>
</Layout>
