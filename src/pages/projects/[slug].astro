---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const { title, titleZh, description, descriptionZh, tags, github, stars, date, language } = project.data;

const dateStr = date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title={`${title} — 77652189`} description={descriptionZh}>
  <article>
    <a href="/projects" class="text-sm text-slate-400 hover:text-indigo-600 transition-colors mb-8 inline-block">
      ← 所有项目
    </a>

    <header class="mb-10">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h1 class="text-3xl font-bold text-slate-900">{title}</h1>
          <p class="text-lg text-slate-400 mt-1">{titleZh}</p>
        </div>
        {stars > 0 && (
          <span class="text-amber-500 flex items-center gap-1 text-sm shrink-0 mt-1">
            ★ {stars}
          </span>
        )}
      </div>

      <div class="mt-4 space-y-1">
        <p class="text-slate-600 leading-relaxed">{descriptionZh}</p>
        <p class="text-sm text-slate-400">{description}</p>
      </div>

      <div class="flex flex-wrap gap-2 mt-5">
        {tags.map(tag => (
          <span class="text-xs bg-slate-100 text-slate-500 px-2.5 py-1 rounded-md">{tag}</span>
        ))}
        {language && (
          <span class="text-xs bg-indigo-50 text-indigo-500 px-2.5 py-1 rounded-md">{language}</span>
        )}
      </div>

      <div class="flex items-center gap-4 mt-6">
        <a
          href={github}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-sm bg-slate-900 text-white px-4 py-2 rounded-lg hover:bg-slate-700 transition-colors"
        >
          在 GitHub 查看 ↗
        </a>
        <span class="text-xs text-slate-400">{dateStr}</span>
      </div>
    </header>

    <div class="prose prose-slate max-w-none
      prose-headings:font-semibold
      prose-h2:text-lg prose-h2:mt-8 prose-h2:mb-3
      prose-p:text-slate-600 prose-p:leading-relaxed
      prose-li:text-slate-600
      prose-strong:text-slate-800 prose-strong:font-semibold
      prose-code:text-indigo-600 prose-code:bg-indigo-50 prose-code:px-1 prose-code:rounded prose-code:text-sm prose-code:font-normal
    ">
      <Content />
    </div>
  </article>
</Layout>
