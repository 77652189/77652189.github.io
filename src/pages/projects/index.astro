---
import Layout from '../../layouts/Layout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(allProjects.flatMap(p => p.data.tags))].sort();
---

<Layout title="所有项目 — 77652189">
  <div class="mb-10">
    <h1 class="text-2xl font-bold text-slate-900 mb-2">所有项目</h1>
    <p class="text-slate-500 text-sm">All Projects · {allProjects.length} 个</p>
  </div>

  <div class="mb-8 flex flex-wrap gap-2">
    {allTags.map(tag => (
      <span class="text-xs bg-white border border-slate-200 text-slate-500 px-3 py-1 rounded-full">
        {tag}
      </span>
    ))}
  </div>

  <div class="flex flex-col gap-4">
    {sorted.map(project => (
      <ProjectCard
        title={project.data.title}
        titleZh={project.data.titleZh}
        description={project.data.description}
        descriptionZh={project.data.descriptionZh}
        tags={project.data.tags}
        stars={project.data.stars}
        slug={project.slug}
      />
    ))}
  </div>
</Layout>
