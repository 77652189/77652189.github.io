---
import Layout from '../layouts/Layout.astro';
---

<Layout title="留言板 — 知行合一" description="给 Nan 留言，聊技术、合作或任何想说的。">

  <section class="pt-10 sm:pt-14 pb-10">
    <p class="font-mono text-xs text-indigo-500 dark:text-indigo-400 tracking-widest uppercase mb-4">Guestbook</p>
    <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-3">留言板</h1>
    <p class="text-slate-500 dark:text-slate-400 text-sm mb-1">
      随便聊——技术、合作、或者任何想说的。需要 GitHub 账号登录。
    </p>
    <p class="text-slate-400 dark:text-slate-600 text-xs">
      Drop a message — tech, collaboration, or whatever's on your mind. GitHub login required.
    </p>
  </section>

  <div class="h-px mb-10 bg-gradient-to-r from-transparent via-slate-200 dark:via-slate-800 to-transparent"></div>

  <!-- Giscus 留言组件 -->
  <div class="giscus-container min-h-[400px]">
    <script
      src="https://giscus.app/client.js"
      data-repo="77652189/77652189.github.io"
      data-repo-id="R_kgDOSrN9NA"
      data-category="General"
      data-category-id="DIC_kwDOSrN9NM4C-RA4"
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme="light"
      data-lang="zh-CN"
      crossorigin="anonymous"
      async
    ></script>
  </div>

</Layout>

<script is:inline>
  // 与网站明暗模式同步
  function giscusTheme() {
    return document.documentElement.classList.contains('dark') ? 'dark' : 'light';
  }

  function syncGiscus() {
    const iframe = document.querySelector('iframe.giscus-frame');
    if (iframe) {
      iframe.contentWindow.postMessage(
        { giscus: { setConfig: { theme: giscusTheme() } } },
        'https://giscus.app'
      );
    }
  }

  // Giscus 加载完成后同步一次
  window.addEventListener('message', function handler(e) {
    if (e.origin !== 'https://giscus.app') return;
    if (e.data?.giscus?.discussion !== undefined) {
      syncGiscus();
      window.removeEventListener('message', handler);
    }
  });

  // 主题切换时同步
  document.getElementById('theme-toggle')?.addEventListener('click', function () {
    setTimeout(syncGiscus, 50);
  });
</script>
