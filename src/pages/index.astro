---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const techStack = [
  { label: 'Agent & AI', items: ['LangGraph', 'LangChain', 'RAG', 'Multi-Agent', 'FAISS'] },
  { label: 'ML', items: ['PyTorch', 'scikit-learn', 'XGBoost'] },
  { label: 'Engineering', items: ['Python', 'Java', 'Spring Boot', 'MySQL'] },
];
---

<Layout title="Nan — AI Agent Developer">

  <!-- Hero -->
  <section class="pt-10 sm:pt-16 pb-8 sm:pb-10 mb-4">
    <p class="font-mono text-xs text-indigo-500 dark:text-indigo-400 tracking-widest uppercase mb-5">Portfolio</p>

    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-3 text-slate-900 dark:text-white">
      Nan
    </h1>

    <!-- 状态标签 -->
    <div class="inline-flex items-center gap-1.5 text-xs font-mono bg-green-50 dark:bg-green-950/40 text-green-700 dark:text-green-400 border border-green-200 dark:border-green-900 px-3 py-1 rounded-full mb-5">
      <span class="w-1.5 h-1.5 rounded-full bg-green-500 dark:bg-green-400 animate-pulse"></span>
      Open to opportunities
    </div>

    <p class="font-mono text-sm sm:text-base text-slate-400 dark:text-slate-500 mb-6">
      AI Agent Developer&nbsp;&nbsp;·&nbsp;&nbsp;AI 智能体工程师
    </p>

    <p class="text-slate-600 dark:text-slate-400 leading-relaxed text-sm sm:text-base mb-1">
      热衷于构建以 LangGraph 为核心的 AI 智能体系统，专注于 RAG、多 Agent 架构与 LLM 落地应用。
    </p>
    <p class="text-slate-400 dark:text-slate-600 text-xs sm:text-sm mb-8">
      Building LangGraph-based AI agent systems — RAG, multi-agent architecture, and LLM applications.
    </p>

    <div class="flex flex-wrap gap-3">
      <a
        href="https://github.com/77652189"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 text-sm bg-slate-900 dark:bg-white text-white dark:text-slate-950 px-5 py-2.5 rounded-lg font-medium hover:bg-slate-700 dark:hover:bg-slate-100 transition-colors min-h-[44px]"
      >GitHub ↗</a>
      <a
        href="mailto:gao.na@northeastern.edu"
        class="inline-flex items-center gap-2 text-sm border border-slate-300 dark:border-slate-700 text-slate-600 dark:text-slate-400 px-5 py-2.5 rounded-lg hover:border-indigo-400 dark:hover:border-slate-500 hover:text-indigo-600 dark:hover:text-white transition-colors min-h-[44px]"
      >Email ↗</a>
    </div>
  </section>

  <div class="border-t border-slate-200 dark:border-slate-800 mb-10 sm:mb-12"></div>

  <!-- About -->
  <section class="mb-10 sm:mb-14">
    <div class="flex items-center gap-3 mb-7">
      <span class="font-mono text-xs text-slate-400 dark:text-slate-500 uppercase tracking-widest">关于</span>
      <div class="w-10 h-px bg-slate-200 dark:bg-slate-800"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-5 gap-8 sm:gap-10">

      <!-- 左：Education + Experience 并排 -->
      <div class="md:col-span-3 grid grid-cols-1 sm:grid-cols-2 gap-6">

        <div>
          <p class="font-mono text-xs text-slate-400 dark:text-slate-600 uppercase tracking-wider mb-3">Education</p>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <img src="/logos/neu.png" alt="NEU"
                class="w-8 h-8 rounded-md shrink-0 mt-0.5 object-contain bg-white ring-1 ring-slate-200 dark:ring-slate-700" />
              <div>
                <p class="text-sm font-medium text-slate-900 dark:text-slate-100">Northeastern University</p>
                <p class="text-xs text-slate-500 dark:text-slate-500">MS · Information Systems</p>
                <p class="text-xs text-slate-400 dark:text-slate-600 mt-0.5">GPA 4.0 &nbsp;·&nbsp; Expected 2027</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <img src="/logos/csu.png" alt="CSU"
                class="w-8 h-8 rounded-md shrink-0 mt-0.5 object-contain bg-white ring-1 ring-slate-200 dark:ring-slate-700" />
              <div>
                <p class="text-sm font-medium text-slate-900 dark:text-slate-100">Central South University</p>
                <p class="text-xs text-slate-500 dark:text-slate-500">BS · Software Engineering</p>
                <p class="text-xs text-slate-400 dark:text-slate-600 mt-0.5">2023</p>
              </div>
            </div>
          </div>
        </div>

        <div>
          <p class="font-mono text-xs text-slate-400 dark:text-slate-600 uppercase tracking-wider mb-3">Experience</p>
          <div class="flex items-start gap-3">
            <img src="/logos/yixi.png" alt="Yixi Biotech"
              class="w-8 h-8 rounded-md shrink-0 mt-0.5 object-contain bg-white ring-1 ring-slate-200 dark:ring-slate-700" />
            <div>
              <p class="text-sm font-medium text-slate-900 dark:text-slate-100">AI Agent Intern</p>
              <p class="text-xs text-slate-500 dark:text-slate-500">Yixi Biotech · Suzhou</p>
              <p class="text-xs text-slate-400 dark:text-slate-600 mt-0.5">Apr 2026 – Present</p>
            </div>
          </div>
        </div>

      </div>

      <!-- 右：Tech Stack -->
      <div class="md:col-span-2">
        <p class="font-mono text-xs text-slate-400 dark:text-slate-600 uppercase tracking-wider mb-3">Tech Stack</p>
        <div class="space-y-3">
          {techStack.map(group => (
            <div>
              <p class="text-xs text-slate-400 dark:text-slate-600 mb-1.5">{group.label}</p>
              <div class="flex flex-wrap gap-1.5">
                {group.items.map(tech => (
                  <span class="text-xs font-mono bg-slate-100 dark:bg-slate-800/80 text-slate-600 dark:text-slate-400 border border-slate-200 dark:border-slate-700 px-2 py-0.5 rounded">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <div class="border-t border-slate-200 dark:border-slate-800 mb-10 sm:mb-12"></div>

  <!-- 精选项目 -->
  <section>
    <div class="flex items-center justify-between mb-5 sm:mb-6">
      <div class="flex items-center gap-3">
        <span class="font-mono text-xs text-slate-400 dark:text-slate-500 uppercase tracking-widest">精选项目</span>
        <div class="w-10 h-px bg-slate-200 dark:bg-slate-800"></div>
      </div>
      <a href="/projects" class="text-xs font-mono text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 transition-colors">
        全部 {allProjects.length} 个 →
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
      {featured.map(project => (
        <ProjectCard
          title={project.data.title}
          titleZh={project.data.titleZh}
          description={project.data.description}
          descriptionZh={project.data.descriptionZh}
          tags={project.data.tags}
          stars={project.data.stars}
          slug={project.slug}
          date={project.data.date}
        />
      ))}
    </div>
  </section>

</Layout>
