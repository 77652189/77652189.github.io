---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Nan — AI Agent Developer">

  <!-- Hero：无装饰，纯字排版 -->
  <section class="pt-10 sm:pt-16 pb-14 sm:pb-20 mb-4">
    <p class="font-mono text-xs text-indigo-500 dark:text-indigo-400 tracking-widest uppercase mb-5">
      Portfolio
    </p>

    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-3 text-slate-900 dark:text-white">
      Nan
    </h1>

    <p class="font-mono text-sm sm:text-base text-slate-400 dark:text-slate-500 mb-6">
      AI Agent Developer&nbsp;&nbsp;·&nbsp;&nbsp;AI 智能体工程师
    </p>

    <p class="text-slate-600 dark:text-slate-400 leading-relaxed max-w-xl text-sm sm:text-base mb-1">
      热衷于用 AI 解决实际问题，专注于 NLP、数据科学与 AI Agent 方向。
    </p>
    <p class="text-slate-400 dark:text-slate-600 text-xs sm:text-sm mb-8">
      Passionate about solving real-world problems with AI — NLP, data science, and agents.
    </p>

    <div class="flex flex-wrap gap-3">
      <a
        href="https://github.com/77652189"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 text-sm bg-slate-900 dark:bg-white text-white dark:text-slate-950 px-5 py-2.5 rounded-lg font-medium hover:bg-slate-700 dark:hover:bg-slate-100 transition-colors min-h-[44px]"
      >GitHub ↗</a>
      <a
        href="mailto:gao.na@northeastern.edu"
        class="inline-flex items-center gap-2 text-sm border border-slate-300 dark:border-slate-700 text-slate-600 dark:text-slate-400 px-5 py-2.5 rounded-lg hover:border-indigo-400 dark:hover:border-slate-500 hover:text-indigo-600 dark:hover:text-white transition-colors min-h-[44px]"
      >gao.na@northeastern.edu</a>
    </div>
  </section>

  <!-- 分隔线 -->
  <div class="border-t border-slate-200 dark:border-slate-800 mb-10 sm:mb-14"></div>

  <!-- 精选项目 -->
  <section>
    <div class="flex items-center justify-between mb-5 sm:mb-6">
      <div class="flex items-center gap-3">
        <span class="font-mono text-xs text-slate-400 dark:text-slate-500 uppercase tracking-widest">精选项目</span>
        <div class="w-10 h-px bg-slate-200 dark:bg-slate-800"></div>
      </div>
      <a href="/projects" class="text-xs font-mono text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 transition-colors">
        全部 {allProjects.length} 个 →
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
      {featured.map(project => (
        <ProjectCard
          title={project.data.title}
          titleZh={project.data.titleZh}
          description={project.data.description}
          descriptionZh={project.data.descriptionZh}
          tags={project.data.tags}
          stars={project.data.stars}
          slug={project.slug}
        />
      ))}
    </div>
  </section>

</Layout>
