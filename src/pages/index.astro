---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Projects — 77652189">

  <!-- Hero with dot-grid，明暗双模式 -->
  <section class="relative -mx-6 px-6 pt-12 pb-14 mb-16 overflow-hidden">
    <div class="absolute inset-0 opacity-70 dot-grid"></div>
    <div class="absolute bottom-0 left-0 right-0 h-20 bg-gradient-to-t from-slate-50 dark:from-slate-950 to-transparent"></div>

    <div class="relative">
      <p class="font-mono text-xs text-indigo-500 dark:text-indigo-400 tracking-widest uppercase mb-4">Portfolio</p>
      <h1 class="text-4xl font-bold tracking-tight leading-tight mb-4">
        <span class="text-slate-900 dark:text-white">Hi, 我是 </span>
        <span class="bg-gradient-to-r from-indigo-600 to-violet-600 dark:from-indigo-400 dark:to-cyan-400 bg-clip-text text-transparent">
          77652189
        </span>
      </h1>
      <p class="text-slate-600 dark:text-slate-400 leading-relaxed max-w-lg">
        热衷于用 AI 解决实际问题，专注于 NLP、数据科学与 AI Agent 方向。
      </p>
      <p class="text-slate-400 dark:text-slate-600 text-sm mt-1">
        Passionate about solving real-world problems with AI — NLP, data science, and agents.
      </p>

      <div class="flex gap-3 mt-8">
        <a
          href="https://github.com/77652189"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-sm bg-slate-900 dark:bg-white text-white dark:text-slate-950 px-4 py-2 rounded-lg font-medium hover:bg-slate-700 dark:hover:bg-slate-100 transition-colors"
        >GitHub ↗</a>
        <a
          href="/projects"
          class="inline-flex items-center gap-2 text-sm border border-slate-300 dark:border-slate-700 text-slate-600 dark:text-slate-400 px-4 py-2 rounded-lg hover:border-indigo-400 dark:hover:border-slate-500 hover:text-indigo-600 dark:hover:text-white transition-colors"
        >所有项目</a>
      </div>
    </div>
  </section>

  <!-- Featured projects -->
  <section>
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-3">
        <span class="font-mono text-xs text-slate-400 dark:text-slate-500 uppercase tracking-widest">精选项目</span>
        <div class="w-12 h-px bg-slate-200 dark:bg-slate-800"></div>
      </div>
      <a href="/projects" class="text-xs font-mono text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 transition-colors">
        全部 {allProjects.length} 个 →
      </a>
    </div>

    <div class="flex flex-col gap-3">
      {featured.map(project => (
        <ProjectCard
          title={project.data.title}
          titleZh={project.data.titleZh}
          description={project.data.description}
          descriptionZh={project.data.descriptionZh}
          tags={project.data.tags}
          stars={project.data.stars}
          slug={project.slug}
        />
      ))}
    </div>
  </section>

</Layout>

<style>
  /* 点阵背景，明暗双模式 */
  .dot-grid {
    background-image: radial-gradient(circle at 1px 1px, rgb(203 213 225) 1px, transparent 0);
    background-size: 28px 28px;
  }
  :global(.dark) .dot-grid {
    background-image: radial-gradient(circle at 1px 1px, rgb(51 65 85) 1px, transparent 0);
  }
</style>
