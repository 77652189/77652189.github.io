---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Nan" description="Page not found">
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <p class="font-mono text-xs text-indigo-500 dark:text-indigo-400 tracking-widest uppercase mb-6">404</p>
    <h1 class="text-5xl font-bold text-slate-900 dark:text-white mb-4">Not Found</h1>
    <p class="text-slate-500 dark:text-slate-400 mb-2">这个页面不存在</p>
    <p class="text-slate-400 dark:text-slate-600 text-sm mb-10">The page you're looking for has moved or never existed.</p>
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm font-mono text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 transition-colors"
    >← 返回首页</a>
  </div>
</Layout>
