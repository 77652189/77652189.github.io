---
interface Props {
  title: string;
  description?: string;
}

const { title, description = '项目展示' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <!-- 防止切换主题时闪烁 -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>

  <body class="bg-slate-50 text-slate-800 dark:bg-slate-950 dark:text-slate-300 min-h-screen antialiased transition-colors duration-200">

    <nav class="border-b border-slate-200 dark:border-slate-800 bg-white/90 dark:bg-slate-950/90 backdrop-blur-sm sticky top-0 z-10">
      <div class="max-w-5xl mx-auto px-4 sm:px-8 py-4 flex items-center justify-between">
        <a href="/" class="font-mono text-sm font-medium text-slate-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
          Nan
        </a>

        <div class="flex items-center gap-3 sm:gap-5 text-sm">
          <!-- 首页：小屏隐藏（logo 本身已链接首页） -->
          <a
            href="/"
            class:list={['hidden sm:inline transition-colors', currentPath === '/'
              ? 'text-slate-900 dark:text-white font-medium'
              : 'text-slate-500 hover:text-slate-900 dark:hover:text-white']}
          >首页<span class="hidden lg:inline text-slate-300 dark:text-slate-700"> · </span><span class="hidden lg:inline">Home</span></a>

          <a
            href="/projects"
            class:list={['transition-colors', currentPath.startsWith('/projects')
              ? 'text-slate-900 dark:text-white font-medium'
              : 'text-slate-500 hover:text-slate-900 dark:hover:text-white']}
          >项目<span class="hidden lg:inline text-slate-300 dark:text-slate-700"> · </span><span class="hidden lg:inline">Projects</span></a>

          <a
            href="/Nan_Resume.pdf"
            target="_blank"
            rel="noopener"
            class="text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors"
          >简历<span class="hidden lg:inline text-slate-300 dark:text-slate-700"> · </span><span class="hidden lg:inline">Resume</span></a>

          <a
            href="https://github.com/77652189"
            target="_blank"
            rel="noopener"
            class="text-slate-500 hover:text-slate-900 dark:hover:text-white transition-colors"
          >GitHub ↗</a>

          <!-- 明暗切换 — 44×44px 触摸目标 -->
          <button
            id="theme-toggle"
            aria-label="切换主题"
            class="flex items-center justify-center w-9 h-9 rounded-lg text-slate-400 hover:text-slate-700 dark:text-slate-500 dark:hover:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
          >
            <!-- 月亮：浅色模式 -->
            <svg class="w-4 h-4 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
            <!-- 太阳：深色模式 -->
            <svg class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- 主内容：小屏 px-4，大屏 px-8 -->
    <main class="max-w-5xl mx-auto px-4 sm:px-8 py-8 sm:py-12">
      <slot />
    </main>

    <footer class="border-t border-slate-200 dark:border-slate-800 mt-16 sm:mt-20">
      <div class="max-w-5xl mx-auto px-4 sm:px-8 py-6 sm:py-8 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs font-mono text-slate-400 dark:text-slate-700">
        <div class="flex items-center gap-4">
          <a href="mailto:gao.na@northeastern.edu" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
            gao.na@northeastern.edu
          </a>
          <span class="text-slate-300 dark:text-slate-800">·</span>
          <a href="https://github.com/77652189" target="_blank" rel="noopener" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
            GitHub
          </a>
          <span class="text-slate-300 dark:text-slate-800">·</span>
          <a href="https://linkedin.com/in/totalwar" target="_blank" rel="noopener" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
            LinkedIn
          </a>
        </div>
        <span>Built with <a href="https://astro.build" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">Astro</a></span>
      </div>
    </footer>

    <script is:inline>
      document.getElementById('theme-toggle')?.addEventListener('click', function () {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    </script>

  </body>
</html>
